# Freepik Credit Tracker - environment overrides (optional)
# All values are optional; defaults work out of the box.

# Path to the SQLite database file (default: ./freepik_tracker.db)
# FCT_DB_PATH=./freepik_tracker.db

# Bind host / port for uvicorn (when launched manually you can pass --host/--port)
# FCT_HOST=127.0.0.1
# FCT_PORT=8765
